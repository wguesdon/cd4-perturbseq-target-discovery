# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Environment / secrets
.env
.env.*

# Data (large and/or restricted — keep folder structure, ignore contents)
# data/external is reproduced exactly by scripts/fetch_priors.sh, so we ignore the
# payload rather than vendor ~10 MB of third-party tables.
data/raw/*
data/interim/*
data/processed/*
data/external/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# Single-cell / genomics artifacts (never commit these anywhere)
*.h5ad
*.h5mu
*.h5
*.loom
*.zarr/
*.mtx
*.mtx.gz

# Notebook checkpoints
.ipynb_checkpoints/

# Quarto render output. `reports/report.html` IS COMMITTED, deliberately: it is ~7 MB with resources
# embedded, and it is the submission artifact. It carries its own render timestamp and the commit it
# was built from, so a stale copy is self-evident. Rebuild with:
#   QUARTO_PYTHON="$PWD/.venv/bin/python" quarto render reports/report.qmd --to html
# The scratch directories below are not committed.
/.quarto/
reports/*_files/
reports/.jupyter_cache/

# Third-party PDFs. The source preprint and any downloaded papers stay local. They are other
# people's copyrighted layout even when the text is CC BY, the repo goes PUBLIC before the
# deadline, and nothing in the pipeline reads them. Cite them; do not vendor them.
*.pdf

# OS cruft
.DS_Store

# Session log (kept local, not committed)
SESSION_SUMMARY.md

# Local-only working notes
*.local.md
